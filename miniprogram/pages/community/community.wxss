.page {
  min-height: 100vh;
  position: relative;
  background: #0c0907;
  color: #f6ead4;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

.atmosphere {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.atmosphere-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
}

.atmosphere-glow-a {
  width: 420rpx;
  height: 420rpx;
  left: -80rpx;
  top: 120rpx;
  background: rgba(122, 46, 40, 0.28);
}

.atmosphere-glow-b {
  width: 360rpx;
  height: 360rpx;
  right: -60rpx;
  top: 480rpx;
  background: rgba(212, 180, 131, 0.12);
}

.atmosphere-vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, transparent 40%, rgba(0, 0, 0, 0.55) 100%);
}

.shell {
  position: relative;
  z-index: 1;
  height: 100%;
  padding: 36rpx 28rpx 80rpx;
  box-sizing: border-box;
}

.panel {
  padding: 36rpx 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(212, 180, 131, 0.18);
  background: linear-gradient(165deg, rgba(28, 20, 16, 0.92), rgba(12, 9, 7, 0.96));
  margin-bottom: 24rpx;
}

.ornament {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ornament-rule {
  flex: 1;
  height: 1rpx;
  background: rgba(212, 180, 131, 0.28);
}

.ornament-dot {
  color: #d4b483;
  font-size: 18rpx;
}

.eyebrow {
  color: #a89478;
  font-size: 22rpx;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  margin-bottom: 12rpx;
}

.title {
  font-family: "Songti SC", "STSong", Georgia, serif;
  font-size: 44rpx;
  color: #f3e6d0;
  line-height: 1.25;
  margin-bottom: 20rpx;
}

.quote-panel .quote-text {
  font-family: "Songti SC", "STSong", Georgia, serif;
  font-size: 36rpx;
  color: #f3e6d0;
  line-height: 1.6;
  margin-bottom: 18rpx;
}

.quote-source {
  color: #d4b483;
  font-size: 24rpx;
  font-family: "Songti SC", "STSong", serif;
  line-height: 1.6;
}

.section-label {
  color: #d4b483;
  font-size: 26rpx;
  letter-spacing: 0.12em;
  margin-bottom: 18rpx;
  font-family: "Songti SC", "STSong", serif;
}

.bg-tip {
  color: rgba(168, 148, 120, 0.85);
  font-size: 22rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.note-input {
  width: 100%;
  min-height: 140rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(212, 180, 131, 0.06);
  border: 1rpx solid rgba(212, 180, 131, 0.18);
  color: #f6ead4;
  font-size: 26rpx;
  line-height: 1.65;
  box-sizing: border-box;
}

.note-placeholder {
  color: rgba(168, 148, 120, 0.6);
}

.note-meta {
  margin-top: 12rpx;
  text-align: right;
  color: rgba(168, 148, 120, 0.7);
  font-size: 22rpx;
}

.bg-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.bg-cell {
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(212, 180, 131, 0.18);
  background: rgba(0, 0, 0, 0.2);
  padding: 10rpx;
  text-align: center;
  transition: border-color 0.2s, transform 0.2s;
}

.bg-cell-on {
  border-color: #d4b483;
  box-shadow: 0 0 0 2rpx rgba(212, 180, 131, 0.35);
}

.bg-cell-locked {
  opacity: 0.55;
}

.bg-cell-img-wrap {
  position: relative;
  width: 100%;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #1c120f;
}

.bg-cell-img {
  width: 100%;
  height: 100%;
}

.bg-cell-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(168, 148, 120, 0.6);
  font-size: 22rpx;
}

.bg-cell-lock {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.55);
  color: #d4b483;
  font-size: 22rpx;
  letter-spacing: 0.08em;
}

.bg-cell-name {
  color: #f3e6d0;
  font-size: 22rpx;
  margin-top: 8rpx;
  font-family: "Songti SC", "STSong", serif;
}

.bg-cell-book {
  color: rgba(168, 148, 120, 0.85);
  font-size: 20rpx;
  margin-top: 2rpx;
}

.preview-wrap {
  width: 100%;
  border-radius: 18rpx;
  overflow: hidden;
  background: #1c120f;
  border: 1rpx solid rgba(212, 180, 131, 0.18);
  margin-bottom: 24rpx;
}

.preview-img {
  display: block;
  width: 100%;
}

.preview-empty {
  padding: 60rpx 28rpx;
  text-align: center;
  color: rgba(168, 148, 120, 0.7);
  font-size: 24rpx;
  line-height: 1.7;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1.5;
  padding: 16rpx 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #8a3a34, #5c221e);
  color: #f6ead4;
  border: 1rpx solid rgba(212, 180, 131, 0.35);
}

.btn-ghost {
  background: transparent;
  color: #d4b483;
  border: 1rpx solid rgba(212, 180, 131, 0.4);
}

.btn-text {
  flex: none;
  width: 100%;
  background: transparent;
  color: rgba(212, 180, 131, 0.85);
  border: none;
  font-size: 26rpx;
}

.btn-small {
  flex: none;
  width: 220rpx;
  font-size: 26rpx;
  padding: 12rpx 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.history-item {
  display: flex;
  gap: 18rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(212, 180, 131, 0.05);
  border: 1rpx solid rgba(212, 180, 131, 0.12);
}

.history-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #1c120f;
}

.history-thumb-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed rgba(212, 180, 131, 0.3);
}

.history-thumb-date {
  color: rgba(212, 180, 131, 0.8);
  font-size: 22rpx;
  font-family: "Songti SC", serif;
}

.history-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.history-date {
  color: #d4b483;
  font-size: 22rpx;
  font-family: "Songti SC", serif;
}

.history-quote {
  color: rgba(246, 234, 212, 0.9);
  font-size: 24rpx;
  line-height: 1.55;
  font-family: "Songti SC", serif;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.history-note {
  color: rgba(168, 148, 120, 0.9);
  font-size: 22rpx;
  line-height: 1.55;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.footer-entry {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 48rpx;
}

.journal-canvas-offscreen {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 750px;
  height: 1400px;
}

.preview-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  box-sizing: border-box;
}

.preview-modal {
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  background: linear-gradient(165deg, rgba(28, 20, 16, 0.98), rgba(12, 9, 7, 0.98));
  border: 1rpx solid rgba(212, 180, 131, 0.3);
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
}

.modal-quote {
  font-family: "Songti SC", "STSong", serif;
  font-size: 34rpx;
  color: #f3e6d0;
  line-height: 1.6;
  margin: 12rpx 0 16rpx;
}

.modal-source {
  color: #d4b483;
  font-size: 24rpx;
  font-family: "Songti SC", serif;
  margin-bottom: 24rpx;
}

.modal-note {
  color: rgba(246, 234, 212, 0.88);
  font-size: 26rpx;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.modal-note-empty {
  color: rgba(168, 148, 120, 0.6);
}
