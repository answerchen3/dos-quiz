page {
  background: #0c0907;
  color: #f6ead4;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

view,
text,
button,
image {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: none;
}
